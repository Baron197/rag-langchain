# Defaults = keyless "fake" providers -> `cp .env.example .env` runs with no key.
LLM_PROVIDER=fake
EMBEDDING_PROVIDER=fake

# OpenAI (pip install langchain-openai)
OPENAI_API_KEY=sk-replace-me
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local Hugging Face, free, no key (pip install langchain-huggingface transformers sentence-transformers torch)
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Retrieval / chunking
RETRIEVAL_MODE=vector      # vector | hybrid (BM25 + vector via EnsembleRetriever)
TOP_K=4
CHUNK_SIZE=1500
CHUNK_OVERLAP=150
DOCS_DIR=data/docs

# Vector store: "memory" (default, in-process) or "pgvector" (Postgres + pgvector).
# pgvector persists embeddings -> ingest once, queries connect. Needs a running DB and:
#   pip install langchain-postgres "psycopg[binary]>=3.1"
VECTOR_BACKEND=memory
PG_DSN=postgresql://rag:rag@localhost:5432/rag
PG_COLLECTION=rag_lc_docs

# Answer cache (LRU): repeats are served from memory at zero cost.
ENABLE_CACHE=true
CACHE_SIZE=256

# UI auth: shared password for the Ask / Analytics / Evaluation pages (Guide is
# always public). Leave BLANK to disable the gate (local dev); set it to require
# login. Read by the Streamlit UI, not the API.
APP_PASSWORD=

# API auth (optional): if set, the API requires a matching X-API-Key header on
# /query, /ingest, /upload (read-only endpoints + /health stay open). Blank =
# open. The UI forwards it automatically -- set the SAME value for API and UI.
API_KEY=
